{
  "name": "nexus-realms",
  "version": "0.1.0",
  "description": "Nexus Realms — Web MMORPG",
  "private": true,
  "scripts": {
    "dev:client": "vite",
    "build:client": "tsc && vite build",
    "dev:server": "tsx watch src/server/main.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.87.0",
    "ws": "^8.18.0",
    "pg": "^8.13.0",
    "ioredis": "^5.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@playwright/test": "^1.48.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@types/pg": "^8.11.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
